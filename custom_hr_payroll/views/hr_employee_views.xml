<odoo>
    <record id="view_hr_employee_form_inherit" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form" />
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Deducciones y Rentas Exentas">
                    <group>
                        <field name="intereses_prestamo_vivienda" />
                        <field name="derecho_a_dependientes" />
                        <field name="pagos_salud_prepagada" />
                    </group>
                    <group>
                        <field name="aportes_voluntarios_pensiones" />
                        <field name="aportes_voluntarios_pensiones_adicional" />
                        <field name="aportes_afc_avc" />
                    </group>
                    <group>
                        <field name="indemnizacion_accidente_trabajo_enfermedad" />
                        <field name="indemnizacion_proteccion_maternidad" />
                        <field name="gasto_entierro_trabajador" />
                    </group>
                    <group>
                        <field name="otras_rentas_exentas" />
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
