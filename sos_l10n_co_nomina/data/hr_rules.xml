        <!--reglas BASICO-->
        <record id="salario_basico_rule" model="hr.salary.rule">
            <field name="category_id" ref="sos_l10n_co_nomina.BASICO"/>
            <field name="name">Salario básico total</field>
            <field name="sequence">5</field>
            <field name="code">BAS</field>
            <field name="condition_select">python</field>
            <field name="condition_python">
result = 'WORK100' in worked_days
            </field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
valor_dia = contract.wage / 30
dias = worked_days['WORK100'].number_of_days
result = dias * valor_dia
            </field>
            <field name="struct_id" ref="sos_l10n_co_nomina.estructura_basica_colombiana"/>
        </record>

        <record id="auxilio_transporte_rule" model="hr.salary.rule">
            <field name="category_id" ref="sos_l10n_co_nomina.AUXILIO"/>
            <field name="name">Auxilio de Transporte</field>
            <field name="sequence">15</field>
            <field name="code">AUXT</field>
            <field name="condition_select">python</field>
            <field name="condition_python">
if contract.wage &lt; (2 * SMMLV) and ('WORK100' in worked_days):
    result = 1
else:
    result = 0
            </field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
dias = 0
if worked_days['WORK100']:
    dias = worked_days['WORK100'].number_of_days

if contract.wage &lt; (2 * SMMLV):
    result = (VAUXT * dias) / 30
else:
    result = 0
            </field>
            <field name="struct_id" ref="sos_l10n_co_nomina.estructura_basica_colombiana"/>
        </record>

