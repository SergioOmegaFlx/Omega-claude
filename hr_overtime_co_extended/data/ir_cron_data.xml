<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_check_open_attendances" model="ir.cron">
            <field name="name">Asistencia: Notificar Sesiones Abiertas</field>
            <field name="model_id" ref="model_hr_employee"/>
            <field name="state">code</field>
            <field name="code">model._cron_notify_open_attendances()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall" eval="(DateTime.now().replace(hour=19, minute=0, second=0)).strftime('%Y-%m-%d %H:%M:%S')" />
        </record>
    </data>
</odoo>