<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_overtime_tree" model="ir.ui.view">
        <field name="name">hr.overtime.list</field>
        <field name="model">hr.overtime</field>
        <field name="arch" type="xml">
            <list string="Overtime Records" editable="bottom">
                <field name="employee_id"/>
                <field name="attendance_id"/>
                <field name="type_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="duration" sum="Total Hours"/>
                <field name="amount" sum="Total Amount"/>
            </list>
        </field>
    </record>

    <record id="view_hr_overtime_form" model="ir.ui.view">
        <field name="name">hr.overtime.form</field>
        <field name="model">hr.overtime</field>
        <field name="arch" type="xml">
            <form string="Overtime Record">
                <sheet>
                    <group>
                        <field name="employee_id"/>
                        <field name="attendance_id"/>
                        <field name="type_id"/>
                        <field name="date_start"/>
                        <field name="date_end"/>
                        <field name="duration"/>
                        <field name="amount"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    
    <record id="action_hr_overtime" model="ir.actions.act_window">
        <field name="name">Overtime Records</field>
        <field name="res_model">hr.overtime</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_hr_overtime_type" model="ir.actions.act_window">
        <field name="name">Overtime Types</field>
        <field name="res_model">hr.overtime.type</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>