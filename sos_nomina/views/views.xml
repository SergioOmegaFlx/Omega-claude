<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
  
    <record id="hr_contract_view_form" model="ir.ui.view">
	    <field name="name">hr.contract.view.form</field>
	    <field name="model">hr.contract</field>
	    <field name="inherit_id" ref="hr_contract.hr_contract_view_form"/>
	    <field name="arch" type="xml">
	        <group name="salary" position="after">
	            <group name="salary">
					<label for="auxilio_transporte"/>
					<div class="o_row mw-50" name="auxilio_transporte">
						<field name="auxilio_transporte" class="oe_inline o_hr_narrow_field" nolabel="1"/>
						<div class="mb-3" name="auxtte_period_label">/ month</div>
					</div>
				</group>
			</group>
	    </field>
	</record>

	<record id="sos_hr_payslip_view_form" model="ir.ui.view">
	    <field name="name">sos.hr.payslip.view.form</field>
	    <field name="model">hr.payslip</field>
	    <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
	    <field name="arch" type="xml">
	        <field name="worked_days_line_ids" position="replace">
	        	<field name="worked_days_line_ids" readonly="state in ['cancel', 'done', 'paid']" invisible=" not use_worked_day_lines">
					<list string="Worked Days" editable="bottom" create="1" delete="0">
						<field name="work_entry_type_id" readonly="0" force_save="1"/>
						<field name="name"/>
						<field name="number_of_days" sum="Total Working Days" readonly="0" force_save="1"/>
						<field name="number_of_hours" widget="float_time" sum="Total Working Hours" readonly="0" force_save="1"/>
						<field name="amount" readonly="1" sum="Total Amount" force_save="1" column_invisible="True"/>
						<field name="ytd" readonly="1" force_save="1" column_invisible="not parent.ytd_computation" optional="show"/>
						<field name="is_paid" readonly="1" column_invisible="True" force_save="1"/>
						<field name="sequence" readonly="1" column_invisible="True" force_save="1"/>
						<field name="currency_id" column_invisible="True"/>
					</list>
					<form string="Worked Day">
						<group col="4">
							<field name="work_entry_type_id"/>
							<field name="name"/>
							<field name="sequence"/>
							<field name="number_of_days"/>
							<field name="number_of_hours" widget="float_time"/>
							<field name="amount" invisible="1"/>
							<field name="ytd" readonly="1" invisible="not parent.ytd_computation"/>
							<field name="is_paid"/>
							<field name="contract_id"/>
							<field name="currency_id" invisible="1"/>
						</group>
					</form>
				</field>    
			</field>
	    </field>
	</record>

	<record id="view_hr_payslip_worked_days_tree" model="ir.ui.view">
		<field name="name">hr.payslip.worked.days.tree</field>
		<field name="model">hr.payslip.worked_days</field>
		<field name="arch" type="xml">
			<list string="Worked Days" create="true" edit="true">
				<!-- Define los campos que quieres mostrar en la vista tree -->
				<field name="work_entry_type_id"/>
				<field name="name"/>
				<field name="number_of_days"/>
				<field name="number_of_hours"/>
				<field name="payslip_id"/>
				<field name="payslip_run_id" string="Lote"/>
				<!-- Agrega otros campos según sea necesario -->
			</list>
		</field>
	</record>

	<record id="view_hr_payslip_input_tree" model="ir.ui.view">
		<field name="name">hr.payslip.input.tree</field>
		<field name="model">hr.payslip.input</field>
		<field name="arch" type="xml">
			<list string="Input" create="true" edit="true">
				<!-- Define los campos que quieres mostrar en la vista tree -->
				<field name="input_type_id"/>
				<field name="name"/>
				<field name="amount"/>
				<field name="payslip_id"/>
				<field name="payslip_run_id" string="Lote"/>
				<!-- Agrega otros campos según sea necesario -->
			</list>
		</field>
	</record>

	<!-- Acción para cargar la vista tree del modelo hr.payslip.worked_days -->
	<record id="action_hr_payslip_worked_days_tree" model="ir.actions.act_window">
		<field name="name">Worked Days</field>
		<field name="res_model">hr.payslip.worked_days</field>
		<field name="view_mode">list,form</field> <!-- tree y form para habilitar ambas vistas -->
		<field name="view_id" ref="view_hr_payslip_worked_days_tree"/> <!-- Refiriendo a la vista tree creada -->
	</record>

	<record id="action_hr_payslip_input_tree" model="ir.actions.act_window">
		<field name="name">Input</field>
		<field name="res_model">hr.payslip.input</field>
		<field name="view_mode">list,form</field> <!-- tree y form para habilitar ambas vistas -->
		<field name="view_id" ref="view_hr_payslip_input_tree"/> <!-- Refiriendo a la vista tree creada -->
	</record>

	<menuitem
        id="menu_hr_payroll_novedades_root"
        name="Novedades"
        parent="hr_work_entry_contract_enterprise.menu_hr_payroll_root"
        sequence="60"
        groups="hr_payroll.group_hr_payroll_user"/>

	<!-- Definición del menú -->
	
	<menuitem id="menu_hr_payslip_worked_days"
          name="Tiempo"
          parent="menu_hr_payroll_novedades_root"
          action="action_hr_payslip_worked_days_tree"
          sequence="10"/>

	<menuitem id="menu_hr_payslip_input"
          name="Valor"
          parent="menu_hr_payroll_novedades_root"
          action="action_hr_payslip_input_tree"
          sequence="20"/>


  </data>
</odoo>