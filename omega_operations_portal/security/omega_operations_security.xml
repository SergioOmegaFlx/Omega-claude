<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================
         OMEGA OPERATIONS PORTAL - SECURITY RULES
         ============================================ -->

    <!-- Grupo para usuarios de operaciones -->
    <record id="group_omega_operations_user" model="res.groups">
        <field name="name">OMEGA Operations User</field>
        <field name="category_id" ref="base.module_category_services_project"/>
        <field name="implied_ids" eval="[(4, ref('project.group_project_user'))]"/>
    </record>

    <record id="group_omega_operations_manager" model="res.groups">
        <field name="name">OMEGA Operations Manager</field>
        <field name="category_id" ref="base.module_category_services_project"/>
        <field name="implied_ids" eval="[(4, ref('omega_operations_portal.group_omega_operations_user'))]"/>
    </record>

    <!-- ============================================
         RECORD RULES - PORTAL CLIENT VISIBILITY
         ============================================ -->

    <!-- Regla: Clientes del portal solo ven proyectos donde son el partner -->
    <record id="project_portal_personal_rule" model="ir.rule">
        <field name="name">Portal: Ver solo mis proyectos de operación</field>
        <field name="model_id" ref="project.model_project_project"/>
        <field name="domain_force">[('partner_id', 'child_of', user.partner_id.commercial_partner_id.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Regla: Clientes del portal solo ven tareas marcadas como visibles -->
    <record id="task_portal_visible_rule" model="ir.rule">
        <field name="name">Portal: Ver solo tareas/hitos visibles</field>
        <field name="model_id" ref="project.model_project_task"/>
        <field name="domain_force">[
            ('project_id.partner_id', 'child_of', user.partner_id.commercial_partner_id.id),
            '|',
            ('is_client_visible', '=', True),
            ('is_alert', '=', True)
        ]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- ============================================
         RECORD RULES - INTERNAL USERS
         ============================================ -->

    <!-- Usuarios de operaciones ven todos los proyectos de operación -->
    <record id="project_operations_user_rule" model="ir.rule">
        <field name="name">Operations: Ver todos los proyectos de operación</field>
        <field name="model_id" ref="project.model_project_project"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('omega_operations_portal.group_omega_operations_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Managers pueden eliminar -->
    <record id="project_operations_manager_rule" model="ir.rule">
        <field name="name">Operations Manager: Full access</field>
        <field name="model_id" ref="project.model_project_project"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('omega_operations_portal.group_omega_operations_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

</odoo>
