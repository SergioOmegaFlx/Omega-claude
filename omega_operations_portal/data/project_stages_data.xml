<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

       <record id="project_stage_new" model="project.task.type">
            <field name="name">📥 Nuevo</field>
            <field name="sequence">10</field>
            <field name="fold">False</field>
        </record>

        <record id="project_stage_in_progress" model="project.task.type">
            <field name="name">⚙️ En Proceso</field>
            <field name="sequence">20</field>
            <field name="fold">False</field>
        </record>

        <record id="project_stage_waiting" model="project.task.type">
            <field name="name">⏳ En Espera</field>
            <field name="sequence">30</field>
            <field name="fold">False</field>
        </record>

        <record id="project_stage_review" model="project.task.type">
            <field name="name">👁️ Revisión Cliente</field>
            <field name="sequence">40</field>
            <field name="fold">False</field>
        </record>

        <record id="project_stage_alert" model="project.task.type">
            <field name="name">⚠️ Novedad - Acción Cliente</field>
            <field name="sequence">50</field>
            <field name="fold">False</field>
        </record>

        <record id="project_stage_done" model="project.task.type">
            <field name="name">✅ Completado</field>
            <field name="sequence">100</field>
            <field name="fold">True</field>
            <field name="is_closed">True</field>
        </record>

        <record id="project_stage_cancelled" model="project.task.type">
            <field name="name">❌ Cancelado</field>
            <field name="sequence">110</field>
            <field name="fold">True</field>
            <field name="is_closed">True</field>
        </record>
    </data>
</odoo>