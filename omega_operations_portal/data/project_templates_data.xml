            <field name="tag_ids" eval="[(6, 0, [
                ref('omega_operations_portal.project_tag_milestone'),
                ref('omega_operations_portal.project_tag_booking')
            ])]"/>
            <!-- ETAPA: Nuevo -->
            <field name="stage_id" ref="omega_operations_portal.project_stage_new"/>
            <!-- ⚠️ USUARIO: Cambia 'base.user_admin' por tu usuario -->
            <field name="user_ids" eval="[(6, 0, [ref('base.user_admin')])]"/>
