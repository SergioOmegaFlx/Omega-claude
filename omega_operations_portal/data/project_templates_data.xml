<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================
             PROBLEMA 2 y 3 SOLUCIONADOS:
             - Cada tarea tiene tag_ids asignados
             - Cada tarea tiene stage_id apuntando a etapa "Nuevo"
             - Cada tarea tiene user_ids con usuario por defecto
             
             ⚠️ IMPORTANTE PARA CAMBIAR USUARIOS:
             Busca todas las líneas que contengan:
                 <field name="user_ids" eval="[(6, 0, [ref('base.user_admin')])]"/>
             
             Y cámbialas por el ID de tu usuario o equipo. Ejemplos:
                 - Un usuario específico: ref('base.user_admin') → ref('tu_modulo.tu_usuario_id')
                 - Usuario actual: Eliminar la línea (se asignará al crear)
                 - Múltiples usuarios: [(6, 0, [ref('user1'), ref('user2')])]
             ============================================ -->


